{
    "name": "viabill/viabill",    
    "version": "9.1.4",
    "type": "prestashop-module",
    "description": "ViaBill payment module for PrestaShop",
    "license": "OSL-3.0",
    "authors": [
        {
            "name": "Written for or by ViaBill",
            "email": "tech@viabill.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.0",
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "ViaBill\\": "src/"
        },
        "classmap": [
            "src/Entity"
        ]
    },
    "config": {
        "prepend-autoloader": false,
        "platform": {
            "php": "8.1"
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"file_exists('.git') && copy('config/pre-commit', '.git/hooks/pre-commit');\""
        ],
        "post-update-cmd": [
            "php -r \"file_exists('.git') && copy('config/pre-commit', '.git/hooks/pre-commit');\""
        ]
    }
}